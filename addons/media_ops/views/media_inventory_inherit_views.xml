<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Billboard Site Form -->
    <record id="view_media_site_form_inherit_ops" model="ir.ui.view">
        <field name="name">media.site.form.inherit.ops</field>
        <field name="model">media.site</field>
        <field name="inherit_id" ref="media_inventory.view_media_site_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_job_cards" type="object" class="oe_stat_button" icon="fa-wrench">
                    <field name="job_card_count" widget="statinfo" string="Job Cards"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Job Cards" name="job_cards">
                    <field name="job_card_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="job_type_id"/>
                            <field name="maintenance_team_id"/>
                            <field name="date"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


    <!-- Extend Media Face Form -->
    <record id="view_media_face_form_inherit_ops" model="ir.ui.view">
        <field name="name">media.face.form.inherit.ops</field>
        <field name="model">media.face</field>
        <field name="inherit_id" ref="media_inventory.view_media_face_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_job_cards" type="object" class="oe_stat_button" icon="fa-wrench">
                    <field name="job_card_count" widget="statinfo" string="Job Cards"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Job Cards" name="job_cards">
                    <field name="job_card_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="job_type_id"/>
                            <field name="maintenance_team_id"/>
                            <field name="date"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extend Artwork History Form -->
    <record id="view_media_artwork_history_form_inherit_ops" model="ir.ui.view">
        <field name="name">media.artwork.history.form.inherit.ops</field>
        <field name="model">media.artwork.history</field>
        <field name="inherit_id" ref="media_inventory.view_media_artwork_history_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='renovation_date']" position="after">
                <field name="maintenance_team_id" 
                       options="{'no_create': True}"
                       invisible="site_category != 'canopy'"/>
            </xpath>
        </field>
    </record>

    <!-- Extend Canopy Form Renovations List -->
    <record id="view_media_canopy_form_inherit_renovations" model="ir.ui.view">
        <field name="name">media.canopy.form.inherit.renovations</field>
        <field name="model">media.canopy</field>
        <field name="inherit_id" ref="media_inventory.view_media_canopy_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='artwork_history']//field[@name='partner_id']" position="after">
                <field name="maintenance_team_id" string="Team"/>
            </xpath>
        </field>
    </record>

</odoo>
