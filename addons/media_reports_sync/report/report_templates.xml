<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sale Order Report Customization -->
    <template id="report_saleorder_document_inherit_item_desc" inherit_id="sale.report_saleorder_document">
        <!-- Custom Table Header -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//thead//tr" position="replace">
            <tr>
                <th name="th_item" class="text-start">ITEM</th>
                <th name="th_item_description" class="text-start">ITEM DESCRIPTION</th>
                <th name="th_priceunit" class="text-end">RATE</th>
                <th name="th_quantity" class="text-end">QUANTITY</th>
                <th name="th_subtotal" class="text-end">Sub- Total</th>
            </tr>
        </xpath>

        <!-- Custom Table Body -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//tbody" position="replace">
            <tbody class="sale_tbody">
                <t t-set="current_subtotal" t-value="0"/>
                <t t-foreach="doc.order_line" t-as="line">
                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>

                    <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                        <t t-if="not line.display_type">
                            <td name="td_item">
                                <span t-field="line.product_id.name"/>
                            </td>
                            <td name="td_item_description">
                                <span t-field="line.item_description"/>
                            </td>
                            <td name="td_priceunit" class="text-end">
                                <span t-field="line.price_unit"/>
                            </td>
                            <td name="td_quantity" class="text-end">
                                <span t-field="line.product_uom_qty"/>
                                <span t-if="'product_uom' in line._fields" t-field="line.product_uom"/>
                                <span t-elif="'product_uom_id' in line._fields" t-field="line.product_uom_id"/>
                            </td>
                            <td name="td_subtotal" class="text-end o_price_total">
                                <span t-field="line.price_subtotal"/>
                            </td>
                        </t>
                        <t t-elif="line.display_type == 'line_section'">
                            <td name="td_section_line" colspan="99">
                                <span t-field="line.name"/>
                            </td>
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subtotal" t-value="0"/>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <td name="td_note_line" colspan="99">
                                <span t-field="line.name"/>
                            </td>
                        </t>
                    </tr>
                </t>
            </tbody>
        </xpath>
    </template>

    <!-- Invoice Report Customization -->
    <template id="report_invoice_document_inherit_item_desc" inherit_id="account.report_invoice_document">
         <!-- Custom Table Header -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//thead//tr" position="replace">
            <tr>
                <th name="th_item" class="text-start">ITEM</th>
                <th name="th_item_description" class="text-start">ITEM DESCRIPTION</th>
                <th name="th_priceunit" class="text-end">RATE</th>
                <th name="th_quantity" class="text-end">QUANTITY</th>
                <th name="th_subtotal" class="text-end">Sub- Total</th>
            </tr>
        </xpath>

        <!-- Custom Table Body -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//tbody" position="replace">
            <tbody class="invoice_tbody">
                <t t-set="current_subtotal" t-value="0"/>
                <t t-foreach="o.invoice_line_ids" t-as="line">
                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>

                    <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                        <t t-if="line.display_type == 'product' or not line.display_type">
                            <td name="td_item">
                                <span t-field="line.product_id.name"/>
                            </td>
                            <td name="td_item_description">
                                <span t-field="line.item_description"/>
                            </td>
                            <td name="td_priceunit" class="text-end">
                                <span t-field="line.price_unit"/>
                            </td>
                            <td name="td_quantity" class="text-end">
                                <span t-field="line.quantity"/>
                                <span t-if="line.product_uom_id" t-field="line.product_uom_id"/>
                            </td>
                            <td name="td_subtotal" class="text-end o_price_total">
                                <span t-field="line.price_subtotal"/>
                            </td>
                        </t>
                        <t t-elif="line.display_type == 'line_section'">
                            <td name="td_section_line" colspan="99">
                                <span t-field="line.name" t-options="{'widget': 'text'}"/>
                            </td>
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subtotal" t-value="0"/>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <td name="td_note_line" colspan="99">
                                <span t-field="line.name" t-options="{'widget': 'text'}"/>
                            </td>
                        </t>
                    </tr>
                </t>
            </tbody>
        </xpath>
    </template>
</odoo>
